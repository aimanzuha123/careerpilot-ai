# ── AI Prompt Optimizer — Environment Variables ──
# Copy this file to .env and fill in your values.

# ── LLM Configuration ──────────────────────────────
# Leave blank to use rule-based mode (no API key needed)
OPENAI_API_KEY=

# Model to use (default: gpt-4o-mini)
LLM_MODEL=gpt-4o-mini

# Temperature for generation (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.7

# Max tokens per LLM response
LLM_MAX_TOKENS=2048

# ── Storage ────────────────────────────────────────
FEEDBACK_DB_PATH=storage/feedback_db.json
EXAMPLE_PROMPTS_PATH=data/example_prompts.json

# ── RAG Settings ───────────────────────────────────
RAG_TOP_K=3
SIMILARITY_THRESHOLD=0.25

# ── Self-Improvement ──────────────────────────────
LEARNING_RATE=0.1
MIN_FEEDBACK_FOR_LEARNING=5
